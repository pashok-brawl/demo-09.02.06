    Создайте конфигурацию для сайтов в /etc/nginx/sites-available/au-team (или добавьте в nginx.conf):

Nginx

# Прокси для Apache на HQ-SRV (через проброшенный порт HQ-RTR)
server {
    listen 80;
    server_name web.au-team.irpo;

    # Включаем аутентификацию для этого хоста (Пункт 10)
    auth_basic "Protected Area";
    auth_basic_user_file /etc/nginx/.htpasswd;

    location / {
        proxy_pass http://IP_HQ-RTR:8080; 
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

# Прокси для Docker на BR-SRV (через проброшенный порт BR-RTR)
server {
    listen 80;
    server_name docker.au-team.irpo;

    location / {
        proxy_pass http://IP_BR-RTR:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

    Сделайте символическую ссылку в sites-enabled (если применимо) и перезапустите Nginx:

Bash

systemctl enable --now nginx
systemctl reload nginx
